{
    "manifest_version": 2.0,
    "id": "zabgpt",
    "name": "ZabGPT",
    "version": "1.0.0",
    "namespace": "ZabGPT",
    "description": "ZabGPT DevOps copilot for incident analysis in Zabbix.",
    "author": "Rohit Sharma",
    "url": "monzphere.com",
    "actions": {
        "zabgpt.settings": {
            "class": "ZabGPTSettings",
            "view": "zabgpt.settings"
        },
        "zabgpt.settings.save": {
            "class": "ZabGPTSettingsSave"
        },
        "zabgpt.query": {
            "class": "ZabGPTQuery"
        },
        "zabgpt.providers": {
            "class": "ZabGPTProviders"
        },
        "voiceai.synthesize": {
            "class": "VoiceAISynthesize"
        },
        "voiceai.translate": {
            "class": "VoiceAITranslate"
        }
    },
    "assets": {
        "css": [
            "zabgpt.css"
        ],
        "js": [
            "zabgpt-core.js",
            "zabgpt-context.js",
            "zabgpt-ui.js",
            "zabgpt-voice.js"
        ]
    }
}
